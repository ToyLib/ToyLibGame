{
  // ------------------------------------------------------------
  // パーティクルの種類（挙動プリセット）
  // "Spark" / "Water" / "Smoke"
  // ------------------------------------------------------------
  "mode": "Smoke",

  // ------------------------------------------------------------
  // GPU バッファ上の最大パーティクル数
  // ※ 多すぎると描画コストが増える
  // ------------------------------------------------------------
  "maxParticles": 10,

  // ------------------------------------------------------------
  // コンポーネント自体の寿命（秒）
  // 0.0 = 無限（Stop() されるまで継続）
  // ------------------------------------------------------------
  "componentLife": 0.0,

  // ------------------------------------------------------------
  // 1 粒あたりの寿命（秒）
  // 寿命が来ると dead → respawn 判定へ
  // ------------------------------------------------------------
  "particleLife": 0.6,

  // ------------------------------------------------------------
  // 粒のサイズ（ワールド空間）
  // Billboard quad のスケールに使用される
  // ------------------------------------------------------------
  "size": 5.5,

  // ------------------------------------------------------------
  // 1 秒あたりのリスポーン試行回数（平均）
  // 0.0 = リスポーンしない
  // ※ 実際は確率処理（GPU側）で近似される
  // ------------------------------------------------------------
  "spawnRatePerSec": 60.0,

  // ------------------------------------------------------------
  // スポーン量を徐々に増やすランプ時間（秒）
  // 0.0 = 即フルレート
  // ------------------------------------------------------------
  "spawnRampSec": 0.6,

  // ------------------------------------------------------------
  // 初速の強さ（direction * spread）
  // 大きいほど勢いよく拡散する
  // ------------------------------------------------------------
  "spread": 2.0,

  // ------------------------------------------------------------
  // 重力（Water 用）
  // 正の値を指定すると下方向へ引っ張られる
  // ------------------------------------------------------------
  "gravity": 0.0,

  // ------------------------------------------------------------
  // 揚力（Smoke 用）
  // 正の値を指定すると上方向へ持ち上がる
  // ------------------------------------------------------------
  "lift": 2.0,

  // ------------------------------------------------------------
  // ブレンドモード
  // true  : 加算合成（火花・発光系）
  // false : 通常アルファ（煙・水）
  // ------------------------------------------------------------
  "additiveBlend": true,

  // ------------------------------------------------------------
  // ウォームスタート
  // true  : 起動直後から粒が散らばった状態になる
  // false : 全粒 dead から開始（立ち上がりが見える）
  // ------------------------------------------------------------
  "warmStart": true,

  // ------------------------------------------------------------
  // エミッタのオフセット（Actor ローカル座標）
  // Actor のワールド行列で変換される
  // ------------------------------------------------------------
  "emitterOffset": [0.0, 0.0, 0.0]
}
